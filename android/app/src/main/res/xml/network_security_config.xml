<?xml version="1.0" encoding="utf-8"?>
<!-- The arcade emulator is served from an in-app HTTP server on loopback.
     Permit cleartext only for 127.0.0.1; everything else stays HTTPS-only. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
